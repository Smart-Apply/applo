{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "web-only",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@smart-apply/web", "dev"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@smart-apply/api", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "preview-shim",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "3016"],
      "port": 3016,
      "autoPort": false
    }
  ]
}
