{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "web-only",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@applo/web", "dev"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@applo/api", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "design-proto",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4321", "--directory", "docs/design"],
      "port": 4321,
      "autoPort": false
    }
  ]
}
