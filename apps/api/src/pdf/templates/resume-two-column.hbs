<!DOCTYPE html>
<html lang="{{language}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{candidateName}} - Resume</title>
</head>
<body>
  <div class="container">
    <!-- LEFT SIDEBAR -->
    <div class="sidebar">
      <!-- Header: Name & Job Title -->
      <div class="resume-header no-break">
        <h1>{{candidateName}}</h1>
        {{#if jobTitle}}
        <p class="job-title">{{jobTitle}}</p>
        {{/if}}
      </div>

      <!-- Contact Section -->
      <div class="contact-section section no-break">
        <h2>{{t 'resume.contact'}}</h2>
        <div class="contact-info">
          {{#if phone}}
          <div class="contact-item">
            <span class="contact-icon">📞</span>
            <span>{{phone}}</span>
          </div>
          {{/if}}
          {{#if email}}
          <div class="contact-item">
            <span class="contact-icon">✉️</span>
            <span>{{email}}</span>
          </div>
          {{/if}}
          {{#if location}}
          <div class="contact-item">
            <span class="contact-icon">📍</span>
            <span>{{location}}</span>
          </div>
          {{/if}}
          {{#if linkedin}}
          <div class="contact-item">
            <span class="contact-icon">🔗</span>
            <span>{{linkedin}}</span>
          </div>
          {{/if}}
          {{#if github}}
          <div class="contact-item">
            <span class="contact-icon">💻</span>
            <span>{{github}}</span>
          </div>
          {{/if}}
          {{#if website}}
          <div class="contact-item">
            <span class="contact-icon">🌐</span>
            <span>{{website}}</span>
          </div>
          {{/if}}
        </div>
      </div>

      <!-- About Me / Summary -->
      {{#if summary}}
      <div class="about-section section no-break">
        <h2>{{t 'resume.about'}}</h2>
        <p class="about-text">{{{summary}}}</p>
      </div>
      {{/if}}

      <!-- Education -->
      {{#if education}}
      <div class="education-section section">
        <h2>{{t 'resume.education'}}</h2>
        {{#each education}}
        <div class="education-item no-break">
          <p class="education-year">{{year}}</p>
          <p class="education-institution">{{institution}}</p>
          <p class="education-degree">{{degree}}{{#if fieldOfStudy}} - {{fieldOfStudy}}{{/if}}</p>
          {{#if gpa}}
          <p class="education-gpa">GPA: {{gpa}}</p>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}

      <!-- Skills -->
      {{#if skills}}
      <div class="skills-section section no-break">
        <h2>{{t 'resume.skills'}}</h2>
        <div class="skills-list">
          {{#each skills}}
          <span class="skill-item">{{this}}</span>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <!-- Skill Categories (alternative format) -->
      {{#if skillCategories}}
      <div class="skills-section section no-break">
        <h2>{{t 'resume.skills'}}</h2>
        {{#each skillCategories}}
        <div class="skill-category">
          <p class="skill-category-title">{{type}}</p>
          <div class="skills-list">
            {{#each skills}}
            <span class="skill-item">{{this}}</span>
            {{/each}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

      <!-- Languages -->
      {{#if languages}}
      <div class="languages-section section no-break">
        <h2>{{t 'resume.languages'}}</h2>
        <div class="languages-list">
          {{#each languages}}
          <span class="language-item">{{name}}{{#if level}} ({{level}}){{/if}}</span>
          {{/each}}
        </div>
      </div>
      {{/if}}
    </div>

    <!-- VERTICAL DIVIDER -->
    <div class="divider"></div>

    <!-- RIGHT MAIN COLUMN -->
    <div class="main-column">
      <!-- Work Experience -->
      {{#if experiences}}
      <div class="experience-section section">
        <h2>{{t 'resume.experience'}}</h2>
        {{#each experiences}}
        <div class="experience-item no-break">
          <h3 class="experience-title">{{title}}</h3>
          <p class="experience-company">{{company}}{{#if location}}, {{location}}{{/if}}</p>
          <p class="experience-date">{{dateRange}}</p>
          {{#if description}}
          <p class="experience-description">{{{description}}}</p>
          {{/if}}
          {{#if achievements}}
          <ul class="experience-achievements">
            {{#each achievements}}
            <li>{{{this}}}</li>
            {{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}

      <!-- Projects -->
      {{#if projects}}
      <div class="projects-section section">
        <h2>{{t 'resume.projects'}}</h2>
        {{#each projects}}
        <div class="project-item no-break">
          <h3 class="project-title">{{name}}</h3>
          {{#if date}}
          <p class="project-date">{{date}}</p>
          {{/if}}
          {{#if description}}
          <p class="project-description">{{{description}}}</p>
          {{/if}}
          {{#if highlights}}
          <ul class="project-highlights">
            {{#each highlights}}
            <li>{{{this}}}</li>
            {{/each}}
          </ul>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}

      <!-- Certifications -->
      {{#if certifications}}
      <div class="certifications-section section">
        <h2>{{t 'resume.certifications'}}</h2>
        {{#each certifications}}
        <div class="certification-item no-break">
          <p class="certification-name">{{name}}</p>
          <p class="certification-issuer">{{issuer}}{{#if date}}, {{date}}{{/if}}</p>
        </div>
        {{/each}}
      </div>
      {{/if}}

      <!-- Awards (optional) -->
      {{#if awards}}
      <div class="awards-section section">
        <h2>{{t 'resume.awards'}}</h2>
        {{#each awards}}
        <div class="award-item no-break">
          <p class="award-name">{{name}}</p>
          <p class="award-issuer">{{issuer}}{{#if date}}, {{date}}{{/if}}</p>
        </div>
        {{/each}}
      </div>
      {{/if}}
    </div>
  </div>
</body>
</html>
