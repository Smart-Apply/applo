<!DOCTYPE html>
<html lang="{{language}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{candidateName}} - {{translations.resume}}</title>
</head>
<body>
  <!-- Header: Name & Contact -->
  <div class="resume-header no-break">
    <h1>{{candidateName}}</h1>
    <div class="contact-info">
      {{#if email}}<span>{{email}}</span>{{/if}}
      {{#if phone}}{{#if email}}<span class="separator">•</span>{{/if}}<span>{{phone}}</span>{{/if}}
      {{#if location}}{{#if phone}}<span class="separator">•</span>{{else}}{{#if email}}<span class="separator">•</span>{{/if}}{{/if}}<span>{{location}}</span>{{/if}}
      {{#if website}}{{#if location}}<span class="separator">•</span>{{else}}{{#if phone}}<span class="separator">•</span>{{else}}{{#if email}}<span class="separator">•</span>{{/if}}{{/if}}{{/if}}<span>{{website}}</span>{{/if}}
      {{#if linkedin}}{{#if website}}<span class="separator">•</span>{{else}}{{#if location}}<span class="separator">•</span>{{else}}{{#if phone}}<span class="separator">•</span>{{else}}{{#if email}}<span class="separator">•</span>{{/if}}{{/if}}{{/if}}{{/if}}<span>{{linkedin}}</span>{{/if}}
    </div>
  </div>

  <!-- Professional Summary (Optional) -->
  {{#if summary}}
  <div class="summary-section no-break">
    <h2>{{translations.professionalSummary}}</h2>
    <p>{{{summary}}}</p>
  </div>
  {{/if}}

  <!-- Education -->
  {{#if education}}
  <div class="section education-section">
    <h2>{{translations.education}}</h2>
    {{#each education}}
    <div class="education-item no-break">
      <div class="item-header">
        <div class="item-left">
          <p class="institution-name">{{institution}}{{#if location}}, {{location}}{{/if}}</p>
          <p class="degree-info">{{degree}}{{#if fieldOfStudy}}, {{fieldOfStudy}}{{/if}}{{#if gpa}}, GPA {{gpa}}{{/if}}</p>
        </div>
        <div class="item-right">
          <p class="date-info">{{year}}</p>
        </div>
      </div>
      {{#if coursework}}
      <p class="coursework">{{../translations.relevantCoursework}}: {{coursework}}</p>
      {{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Work Experience -->
  {{#if experience}}
  <div class="section experience-section">
    <h2>{{translations.experience}}</h2>
    {{#each experience}}
    <div class="experience-item no-break">
      <div class="item-header">
        <div class="item-left">
          <p class="company-name">{{company}}{{#if location}}, {{location}}{{/if}}</p>
          <p class="job-title">{{title}}</p>
        </div>
        <div class="item-right">
          <p class="date-info">{{dateRange}}</p>
        </div>
      </div>
      {{#if description}}
      <p class="description">{{{description}}}</p>
      {{/if}}
      {{#if achievements}}
      <ul class="achievements-list">
        {{#each achievements}}
        <li>{{{this}}}</li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Projects & Extracurricular Activities -->
  {{#if projects}}
  <div class="section projects-section">
    <h2>{{translations.projectsAndActivities}}</h2>
    {{#each projects}}
    <div class="project-item no-break">
      <div class="item-header">
        <div class="item-left">
          <p class="project-name">{{name}}</p>
        </div>
        <div class="item-right">
          <p class="date-info">{{date}}</p>
        </div>
      </div>
      {{#if description}}
      <p class="description">{{{description}}}</p>
      {{/if}}
      {{#if highlights}}
      <ul class="achievements-list">
        {{#each highlights}}
        <li>{{{this}}}</li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Leadership Experience (Optional) -->
  {{#if leadership}}
  <div class="section leadership-section">
    <h2>{{translations.leadershipExperience}}</h2>
    {{#each leadership}}
    <div class="leadership-item no-break">
      <div class="item-header">
        <div class="item-left">
          <p class="organization-name">{{organization}}{{#if location}}, {{location}}{{/if}}</p>
          <p class="role-title">{{role}}</p>
        </div>
        <div class="item-right">
          <p class="date-info">{{dateRange}}</p>
        </div>
      </div>
      {{#if achievements}}
      <ul class="achievements-list">
        {{#each achievements}}
        <li>{{{this}}}</li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Skills / Qualifications -->
  {{#if skills}}
  <div class="section skills-section no-break">
    <h2>{{translations.qualifications}}</h2>
    {{#each skills}}
    <div class="skill-category">
      <p class="skill-category-title">{{type}}:</p>
      <p class="skill-list">{{skills}}</p>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Certifications (Optional) -->
  {{#if certifications}}
  <div class="section certifications-section">
    <h2>{{translations.certifications}}</h2>
    {{#each certifications}}
    <div class="certification-item no-break">
      <p><strong class="certification-name">{{name}}</strong> - <span class="certification-issuer">{{issuer}}</span>{{#if date}}, <span class="certification-date">{{date}}</span>{{/if}}</p>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Languages (Optional) -->
  {{#if languages}}
  <div class="section languages-section no-break">
    <h2>{{translations.languages}}</h2>
    <p class="languages-list">{{languages}}</p>
  </div>
  {{/if}}
</body>
</html>
