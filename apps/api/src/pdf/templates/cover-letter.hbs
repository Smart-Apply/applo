<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cover Letter - {{candidateName}}</title>
</head>
<body>
  <!-- Header -->
  <div class="header">
    <h1>{{candidateName}}</h1>
    <div class="contact-info">
      {{#if email}}
        <a href="mailto:{{email}}">{{email}}</a>
      {{/if}}
      {{#if phone}}
        <span class="separator">|</span>
        {{phone}}
      {{/if}}
      {{#if linkedin}}
        <span class="separator">|</span>
        <a href="{{linkedin}}">LinkedIn</a>
      {{/if}}
      {{#if github}}
        <span class="separator">|</span>
        <a href="{{github}}">GitHub</a>
      {{/if}}
      {{#if location}}
        <span class="separator">|</span>
        {{location}}
      {{/if}}
    </div>
  </div>

  <!-- Date -->
  <div class="date-section">
    {{date}}
  </div>

  <!-- Body Content - includes salutation, body, and closing from LLM -->
  <div class="body-content">
    {{{content}}}
  </div>

  <!-- Signature -->
  <div class="signature">
    <strong>{{candidateName}}</strong>
  </div>

  {{#if footer}}
  <div class="footer">
    {{{footer}}}
  </div>
  {{/if}}
</body>
</html>
