<!DOCTYPE html>
<html lang="{{language}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{candidateName}} - Cover Letter</title>
</head>
<body class="cover-letter">
  <!-- Header: Name & Job Title -->
  <div class="header no-break">
    <h1>{{candidateName}}</h1>
    <p class="job-title">{{#if jobTitle}}{{jobTitle}}{{else}}JOB TITLE{{/if}}</p>
  </div>

  <!-- Date -->
  <div class="date-section">
    {{#if date}}{{date}}{{else}}{{currentDate}}{{/if}}
  </div>

  <!-- Body Content -->
  <div class="body-content">
    {{{content}}}
  </div>

  <!-- Signature -->
  <div class="signature no-break">
    <p>Warm regards,</p>
    <p class="signature-name">{{candidateName}}</p>
  </div>

  <!-- Contact Info Footer -->
  <div class="contact-footer">
    {{#if phone}}<span>{{phone}}</span>{{/if}}
    {{#if email}}{{#if phone}} <span class="separator">•</span> {{/if}}<span>{{email}}</span>{{/if}}
  </div>
</body>
</html>
