<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Deine täglichen Job-Vorschläge</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.5; color: #1f2937; margin: 0; padding: 0; background-color: #f9fafb;">
  <div style="max-width: 600px; margin: 0 auto; padding: 32px 16px;">
    <div style="background: #ffffff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 32px;">
      <div style="text-align: center; margin-bottom: 24px;">
        <h1 style="color: #1B2A49; font-size: 22px; margin: 0 0 4px 0;">Smart Apply</h1>
        <p style="color: #6b7280; font-size: 14px; margin: 0;">Deine täglichen Job-Vorschläge</p>
      </div>

      <h2 style="font-size: 18px; color: #111827; margin: 0 0 8px 0;">
        Hallo {{firstName}}, hier sind {{count}} neue passende Stellen für dich:
      </h2>
      <p style="color: #6b7280; font-size: 14px; margin: 0 0 24px 0;">
        Vom Auto-Apply Agent gefunden &middot; sortiert nach Match-Score.
      </p>

      {{#each suggestions}}
        <div style="border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin-bottom: 12px;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 12px;">
            <div style="flex: 1;">
              <p style="margin: 0; font-weight: 600; color: #111827; font-size: 16px;">
                {{this.jobTitle}}
              </p>
              <p style="margin: 4px 0 0 0; color: #4b5563; font-size: 14px;">
                {{this.company}}{{#if this.location}} &middot; {{this.location}}{{/if}}
              </p>
            </div>
            {{#if this.matchScore}}
              <span style="background: #f59e0b; color: #fff; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; white-space: nowrap;">
                {{this.matchScore}}% Match
              </span>
            {{/if}}
          </div>
        </div>
      {{/each}}

      <div style="text-align: center; margin-top: 28px;">
        <a href="{{inboxUrl}}" style="display: inline-block; background: #1B2A49; color: #fff; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 15px;">
          Alle Vorschläge ansehen
        </a>
      </div>

      <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 32px 0 16px 0;">

      <p style="color: #9ca3af; font-size: 12px; text-align: center; margin: 0;">
        Du erhältst diese E-Mail, weil du die täglichen Auto-Apply Digests aktiviert hast.<br>
        <a href="{{settingsUrl}}" style="color: #6b7280;">Einstellungen ändern</a>
      </p>
    </div>
  </div>
</body>
</html>
