# ─────────────────────────────────────────────────────────────────────────────
# Smart Apply Web — local development environment template.
#
# Copy this file to `.env` and fill in real values:
#   cp apps/web/.env.example apps/web/.env
#
# NEXT_PUBLIC_* values are inlined into the client bundle at build time.
# Staging/prod set these via CI env vars (GitHub Actions → CF Worker build),
# never by reading a committed file.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Cloudflare Turnstile site key (public — safe to commit your real widget key).
# For local smoke tests use the always-passes test key:
#   1x00000000000000000000AA   (always passes)
#   2x00000000000000000000AB   (always blocks)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Sentry (leave unset locally to avoid polluting the prod issue tracker)
# NEXT_PUBLIC_SENTRY_DSN=
