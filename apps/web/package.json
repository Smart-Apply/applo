{
  "name": "@smart-apply/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "echo '\\n⚠️  pnpm start runs the PRODUCTION build (next start). Did you mean `pnpm dev`?\\n     If you really want production locally, run: pnpm start:prod-local\\n' && exit 1",
    "start:prod-local": "next start -p 3001",
    "lint": "eslint",
    "cf:hide-local-env": "test ! -f .env || mv .env .env.bak",
    "cf:restore-local-env": "test ! -f .env.bak || mv .env.bak .env",
    "cf:build": "pnpm run cf:hide-local-env && (NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-https://api.smart-apply.io/api/v1} NEXT_PUBLIC_TURNSTILE_SITE_KEY=${NEXT_PUBLIC_TURNSTILE_SITE_KEY:-0x4AAAAAADEb1zo5z5Pb47Dz} OPEN_NEXT=true opennextjs-cloudflare build); status=$?; pnpm run cf:restore-local-env; exit $status",
    "cf:build:staging": "NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-https://api-staging.smart-apply.io/api/v1} pnpm run cf:build",
    "cf:preview": "pnpm run cf:build && OPEN_NEXT=true opennextjs-cloudflare preview",
    "cf:deploy": "pnpm run cf:build && OPEN_NEXT=true opennextjs-cloudflare deploy",
    "cf:deploy:staging": "pnpm run cf:build:staging && OPEN_NEXT=true opennextjs-cloudflare deploy -- --env staging",
    "cf:upload": "pnpm run cf:build && OPEN_NEXT=true opennextjs-cloudflare upload"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@sentry/nextjs": "^10.57.0",
    "@smart-apply/shared": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@types/turndown": "^5.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.4.11",
    "gpt-tokenizer": "^3.4.0",
    "handlebars": "^4.7.8",
    "isomorphic-dompurify": "^3.17.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "marked": "^18.0.5",
    "next": "^16.2.9",
    "pdfjs-dist": "6.0.227",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.79.0",
    "react-pdf": "^10.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "turndown": "^7.2.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.37",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
